BOARD_DIR=/opt/board-runtime
MQTT_BROKER_URL=mqtt://broker.openclaw.example:1883
# Temporary bring-up default: keep the board on USB serial transport and avoid
# MQTT/AP fallback while Raspberry Pi gadget mode is being validated.
BOARD_TRANSPORT_FORCE=usb
BOARD_RUNTIME_DISABLE_MQTT=1
# Sensitive management APIs (e.g. /pairing/apply-config, /pairing/reset,
# /pairing/ap-mode) require this token in STA mode. AP fallback mode remains
# unauthenticated for physical onboarding.
BOARD_RUNTIME_ADMIN_TOKEN=
BOARD_RUNTIME_WLAN_IFACE=wlan0
BOARD_RUNTIME_AP_IP=192.168.44.1
BOARD_RUNTIME_AP_SSID=claw-pet
BOARD_RUNTIME_AP_PSK=88888888
BOARD_RUNTIME_AP_CHANNEL=6
BOARD_RUNTIME_AP_COUNTRY=CN
BOARD_RUNTIME_PORT=80
BOARD_RUNTIME_WPA_CONF=/etc/wpa_supplicant/wpa_supplicant.conf
BOARD_RUNTIME_WPA_OVERLAY=
BOARD_RUNTIME_AP_UP_CMD=/opt/board-runtime/board-ap-up.sh
BOARD_RUNTIME_AP_DOWN_CMD=/opt/board-runtime/board-ap-down.sh
BOARD_RUNTIME_STA_APPLY_CMD=/opt/board-runtime/board-sta-apply.sh
BOARD_RUNTIME_DISCOVERY_UDP_PORT=19890
BOARD_RUNTIME_DISCOVERY_MDNS_PORT=5353
BOARD_RUNTIME_DISCOVERY_TIMEOUT_MS=0
BOARD_RUNTIME_DISCOVERY_ANNOUNCE_MS=3000
BOARD_SESSION_DONE_HOLD_MS=30000
# Disable video cache preprocessing (too slow for Pi Zero 2 W)
PET_CLAW_FB_DISABLE_CACHE=1
# Prefer the SPI LCD by sysfs identity; set an explicit /dev/fbN only for
# manual override during hardware bring-up.
PET_CLAW_FB_DEV=auto
# Route state WAV cues through ALSA default, which is configured by
# deploy-rpi.sh as a softvol "Master" stage over the VoiceHAT speaker. The
# rotary knob changes that Master control; using plughw here would bypass it.
PET_CLAW_FB_AUDIO_PLAY_DEV=default
PET_CLAW_FB_AUDIO_PREPARE=1
PET_CLAW_FB_AUDIO_GAIN=0.18
PET_CLAW_FB_AUDIO_FADE_IN=0.08
PET_CLAW_FB_AUDIO_RATE=48000
PET_CLAW_FB_AUDIO_CHANNELS=2
PET_CLAW_FB_AUDIO_SAMPLE_FMT=s16
PET_CLAW_SPEAKER_AMP_GPIO=4
# Runtime framebuffer rotation fallback. The Raspberry Pi LCD should normally
# be flipped by the boot overlay (rotate=90), so keep this at 0 for video
# playback performance.
PET_CLAW_FB_ROTATE=0
# Swipe threshold in XPT2046 ADC units (0–4095, NOT pixels). 1500 ≈ 40% of the
# X axis range — required because the resistive panel's per-sample jitter can
# reach ~1000 ADC units and touch_gesture.c does no median filtering. Lower
# values cause taps to be misclassified as swipes. If software de-jitter is
# added later, this can be relaxed to ~400.
PET_SCREEN_SWIPE_THRESHOLD=1500

# Push-to-talk voice input
# GPIO edge source is emitted by board-rotary-input into .voice-button-state.
PET_VOICE_PTT_ENABLED=1
PET_VOICE_BUTTON_ENABLED=1
# I2S microphone ALSA capture device on the shared VoiceHAT soundcard.
PET_VOICE_ARECORD_DEVICE=plughw:CARD=sndrpigooglevoi,DEV=0
PET_VOICE_SAMPLE_RATE=16000
PET_VOICE_CHANNELS=1
PET_VOICE_STT_MODE=speech_recognition
PET_VOICE_STT_LANGUAGE=zh-CN
PET_VOICE_INPUT_VIEW=voice_input
# Avoid long-press restart collision with push-to-talk on GPIO17.
PET_BUTTON_LONG_PRESS_MS=120000
PET_BUTTON_LONG_PRESS_CMD=:

# Completion chime. Play through ALSA default so the rotary Master volume also
# controls these short effects.
PET_TASK_DONE_SOUND_ENABLED=1
PET_TASK_DONE_SOUND_DEV=default
PET_TASK_DONE_SOUND_VOLUME=0.18
PET_TASK_DONE_SOUND_VARIANTS=sparkle,rise,bell,pop,soft
